# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# Both docker-compose.yml and the benchmark app (app/) read from this file.

# --- PgCache image -----------------------------------------------------------
# Pin the version you want to test. Use the -arm64 tag on Apple Silicon,
# or the -amd64 tag on Intel/AMD hosts.
PGCACHE_IMAGE=pgcache/pgcache:0.6.0-arm64

# PgCache mmaps its cache into /dev/shm and refuses to start unless /dev/shm is
# larger than 2x its shared_buffers. 4gb is comfortable for this ~16M-row dataset.
PGCACHE_SHM_SIZE=4gb

# --- Origin Postgres credentials ---------------------------------------------
POSTGRES_USER=demo
POSTGRES_PASSWORD=demo
POSTGRES_DB=demodb

# --- Host port mappings ------------------------------------------------------
PROXY_PORT=5432     # PgCache proxy (what the app treats as "the database")
ORIGIN_PORT=5433    # direct connection to the origin Postgres, for comparison
METRICS_PORT=9090   # PgCache Prometheus metrics endpoint

# --- App connection ----------------------------------------------------------
# Host the app dials for both pools; ports above select origin vs proxy.
PGHOST=localhost
