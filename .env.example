# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# Both docker-compose.yml and the benchmark app (app/) read from this file.

# --- PgCache image -----------------------------------------------------------
# Pin the version you want to test. Use the -arm64 tag on Apple Silicon,
# or the -amd64 tag on Intel/AMD hosts.
PGCACHE_IMAGE=pgcache/pgcache:0.6.0-arm64

# PgCache mmaps its cache into /dev/shm and refuses to start unless /dev/shm is
# larger than 2x its embedded shared_buffers. shared_buffers is derived from the
# RAM available to the Docker VM (not from any env var), so the requirement
# scales with that: ~3GB on an 8GB VM. Bump this if the proxy logs
# "ERROR — /dev/shm is N, need M". 4gb covers a typical 8GB Docker VM.
PGCACHE_SHM_SIZE=4gb

# Anonymous usage telemetry. Off here for clean, reproducible benchmarking.
PGCACHE_TELEMETRY=off

# Queries PgCache validates and populates at startup (semicolon-separated), so
# the cache is warm before the first client connects. These are the three heavy
# aggregate/join queries from app/src/queries.ts; point_lookup is parameterized
# and is not pinnable. Leave empty to disable startup warming.
PGCACHE_PINNED_QUERIES=SELECT tier, count(*) AS total, count(*) FILTER (WHERE country = 'US') AS us_count FROM users GROUP BY tier ORDER BY tier;SELECT u.country, count(o.id) AS order_count, sum(o.total_cents) AS revenue_cents FROM users u JOIN orders o ON u.id = o.user_id WHERE o.status = 'shipped' GROUP BY u.country ORDER BY revenue_cents DESC;SELECT p.category, p.name, sum(oi.quantity) AS units_sold FROM order_items oi JOIN products p ON oi.product_id = p.id GROUP BY p.category, p.id, p.name ORDER BY p.category, units_sold DESC LIMIT 40

# --- Origin Postgres credentials ---------------------------------------------
POSTGRES_USER=demo
POSTGRES_PASSWORD=demo
POSTGRES_DB=demodb

# --- Host port mappings ------------------------------------------------------
PROXY_PORT=5432     # PgCache proxy (what the app treats as "the database")
ORIGIN_PORT=5433    # direct connection to the origin Postgres, for comparison
METRICS_PORT=9090   # PgCache Prometheus metrics endpoint

# --- App connection ----------------------------------------------------------
# Host the app dials for both pools; ports above select origin vs proxy.
PGHOST=localhost
